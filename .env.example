# Copy this file to .env.py and fill in your keys.
#
# ── OpenRouter (required) ──────────────────────────────────────────────────────
# Free signup at https://openrouter.ai  →  Dashboard → API Keys → Create key
# Many models are permanently free (see default model in llm_client.py).
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ── Langfuse (optional — only needed for trace_langfuse.py) ───────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Team / misc ───────────────────────────────────────────────────────────────
TEAM_NAME=your_team_name
LANGFUSE_MEDIA_UPLOAD_ENABLED=false
